	                        <child><object class="GtkButton" id="direction_x_neg"><property name="visible">True</property><property name="label">-X</property><property name="width_request">50</property><property name="height_request">44</property><signal name="clicked" handler="on_direction_x_neg_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
	                        <child><object class="GtkButton" id="direction_y_pos"><property name="visible">True</property><property name="label">+Y</property><property name="width_request">50</property><property name="height_request">44</property><signal name="clicked" handler="on_direction_y_pos_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
	                        <child><object class="GtkButton" id="direction_y_neg"><property name="visible">True</property><property name="label">-Y</property><property name="width_request">50</property><property name="height_request">44</property><signal name="clicked" handler="on_direction_y_neg_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
