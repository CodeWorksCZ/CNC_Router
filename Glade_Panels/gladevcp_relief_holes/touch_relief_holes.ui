<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="2.16"/>
  <object class="GtkWindow" id="window1">
    <property name="visible">True</property>
    <property name="title">Relief Holes Touch Panel</property>
    <child>
      <object class="GtkAlignment" id="align_top">
        <property name="visible">True</property>
        <property name="xalign">0.0</property>
        <property name="yalign">0.0</property>
        <property name="xscale">0.0</property>
        <property name="yscale">0.0</property>
        <property name="top_padding">4</property>
        <property name="left_padding">4</property>
        <child>
          <object class="GtkVBox" id="main_box">
            <property name="visible">True</property>
            <property name="border_width">2</property>
            <property name="spacing">4</property>

            <child>
              <object class="GtkFrame" id="frame_thickness">
                <property name="visible">True</property>
                <property name="label">Tloustka</property>
                <child>
                  <object class="GtkHBox" id="thick_box">
                    <property name="visible">True</property>
                    <property name="spacing">4</property>
                    <child><object class="GtkButton" id="thick_2"><property name="visible">True</property><property name="label">2 mm</property><property name="width_request">90</property><property name="height_request">44</property><signal name="clicked" handler="on_thick_2_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkButton" id="thick_3"><property name="visible">True</property><property name="label">3 mm</property><property name="width_request">90</property><property name="height_request">44</property><signal name="clicked" handler="on_thick_3_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkButton" id="thick_4"><property name="visible">True</property><property name="label">4 mm</property><property name="width_request">90</property><property name="height_request">44</property><signal name="clicked" handler="on_thick_4_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                  </object>
                </child>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property></packing>
            </child>

            <child>
              <object class="GtkFrame" id="frame_diameter">
                <property name="visible">True</property>
                <property name="label">Prumer otvoru</property>
                <child>
                  <object class="GtkVBox" id="dia_box">
                    <property name="visible">True</property>
                    <property name="spacing">4</property>

                    <child><object class="GtkHBox" id="dia_row1"><property name="visible">True</property><property name="spacing">4</property>
                      <child><object class="GtkButton" id="dia_10"><property name="visible">True</property><property name="label">10</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_10_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_15"><property name="visible">True</property><property name="label">15</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_15_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_20"><property name="visible">True</property><property name="label">20</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_20_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_25"><property name="visible">True</property><property name="label">25</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_25_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_30"><property name="visible">True</property><property name="label">30</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_30_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_35"><property name="visible">True</property><property name="label">35</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_35_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    </object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>

                    <child><object class="GtkHBox" id="dia_row2"><property name="visible">True</property><property name="spacing">4</property>
                      <child><object class="GtkButton" id="dia_40"><property name="visible">True</property><property name="label">40</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_40_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_45"><property name="visible">True</property><property name="label">45</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_45_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_50"><property name="visible">True</property><property name="label">50</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_50_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_55"><property name="visible">True</property><property name="label">55</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_55_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_60"><property name="visible">True</property><property name="label">60</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_60_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkEntry" id="entry_custom_dia"><property name="visible">True</property><property name="width_request">80</property><property name="height_request">44</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="custom_set"><property name="visible">True</property><property name="label">Vlastni</property><property name="width_request">90</property><property name="height_request">44</property><signal name="clicked" handler="on_custom_set_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    </object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                  </object>
                </child>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property></packing>
            </child>

            <child>
              <object class="GtkFrame" id="frame_tool">
                <property name="visible">True</property>
                <property name="label">Nastroj / feed</property>
                <child>
                  <object class="GtkHBox" id="tool_box">
                    <property name="visible">True</property>
                    <property name="spacing">4</property>
                    <child><object class="GtkLabel" id="lbl_tool_no"><property name="visible">True</property><property name="label">T</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkEntry" id="entry_tool_no"><property name="visible">True</property><property name="width_request">60</property><property name="height_request">36</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkLabel" id="lbl_tool_dia"><property name="visible">True</property><property name="label">Prumer</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkEntry" id="entry_tool_dia"><property name="visible">True</property><property name="width_request">70</property><property name="height_request">36</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkLabel" id="lbl_feed"><property name="visible">True</property><property name="label">Feed</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkEntry" id="entry_feed"><property name="visible">True</property><property name="width_request">80</property><property name="height_request">36</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkButton" id="refresh"><property name="visible">True</property><property name="label">OK</property><property name="width_request">70</property><property name="height_request">36</property><signal name="clicked" handler="on_refresh_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                  </object>
                </child>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property></packing>
            </child>

            <child>
              <object class="GtkLabel" id="label_status">
                <property name="visible">True</property>
                <property name="label">Vybrano...</property>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property></packing>
            </child>

            <child>
              <object class="GtkButton" id="run_button">
                <property name="visible">True</property>
                <property name="label">VYFREZOVAT OTVOR</property>
                <property name="width_request">520</property>
                <property name="height_request">54</property>
                <signal name="clicked" handler="on_run_clicked"/>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property></packing>
            </child>

          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
