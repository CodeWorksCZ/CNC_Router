o<toolchange> sub



; 1. OCHRANA NÁHLEDU
O100 if [#<_task> EQ 0]
    O100 return [999]
O100 endif

(--- KONTROLA PŘED MĚŘENÍM ---)
O200 if [#<_hal[motion.probe-input]> NE 0]
    (MSG, CHYBA: Sonda je jiz sepnuta! Ocistete setter.)
    M2 (Okamzite zastaveni)
O200 endif

; 2. ZRUŠENÍ KOREKCE (To co ti pomohlo v MDI)
G49

; 3. ODJEZD NA POZICI VÝMĚNY
G90 G53 G0 Z[#<_ini[CHANGE_POSITION]Z>]
G53 G0 X[#<_ini[CHANGE_POSITION]X>] Y[#<_ini[CHANGE_POSITION]Y>]

; 4. VÝMĚNA (M6 vyvolá okno)
M6


; 5. PŘEJEZD NAD SETTER
G90 G53 G0 X[#<_ini[TOOLSENSOR]X>] Y[#<_ini[TOOLSENSOR]Y>]
G53 G0 Z[#<_ini[TOOLSENSOR]Z>]

; 6. MĚŘENÍ A ZÁPIS
G91
G38.2 Z[#<_ini[TOOLSENSOR]MAX_PROBE>] F[#<_ini[TOOLSENSOR]SEARCH_VEL>]
G0 Z3.0
G38.2 Z-5 F[#<_ini[TOOLSENSOR]PROBE_VEL>]
G90

G10 L11 P#<selected_tool> Z0
G43 (Znovu aktivujeme korekci pro nový nástroj)

; 7. UKONČENÍ
G53 G0 Z[#<_ini[CHANGE_POSITION]Z>]
o<toolchange> endsub [1]