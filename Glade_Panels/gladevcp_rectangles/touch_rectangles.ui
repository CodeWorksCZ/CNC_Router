                      <object class="GtkHBox" id="radius_box">
                        <property name="visible">True</property>
                        <property name="spacing">4</property>
	                        <child><object class="GtkLabel" id="lbl_radius"><property name="visible">True</property><property name="label">R</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
