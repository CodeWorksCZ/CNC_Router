                        <child><object class="GtkButton" id="height_30"><property name="visible">True</property><property name="label">30</property><property name="width_request">54</property><property name="height_request">44</property><signal name="clicked" handler="on_height_30_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkButton" id="height_40"><property name="visible">True</property><property name="label">40</property><property name="width_request">54</property><property name="height_request">44</property><signal name="clicked" handler="on_height_40_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkEntry" id="entry_height"><property name="visible">True</property><property name="width_request">60</property><property name="height_request">44</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
