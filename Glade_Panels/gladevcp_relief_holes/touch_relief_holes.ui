<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk+" version="2.16"/>
  <object class="GtkWindow" id="window1">
    <property name="visible">True</property>
    <property name="title">Relief Holes Touch Panel</property>
    <child>
      <object class="GtkAlignment" id="align_top">
        <property name="visible">True</property>
        <property name="xalign">0.0</property>
        <property name="yalign">0.0</property>
        <property name="xscale">0.0</property>
        <property name="yscale">0.0</property>
        <property name="top_padding">4</property>
        <property name="left_padding">4</property>
        <child>
          <object class="GtkVBox" id="main_box">
            <property name="visible">True</property>
            <property name="border_width">2</property>
            <property name="spacing">4</property>

            <child>
              <object class="GtkFrame" id="frame_thickness">
                <property name="visible">True</property>
                <property name="label">Material thickness</property>
                <child>
                  <object class="GtkHBox" id="thick_box">
                    <property name="visible">True</property>
                    <property name="spacing">4</property>
                    <child><object class="GtkButton" id="thick_2"><property name="visible">True</property><property name="label">2 mm</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_thick_2_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkButton" id="thick_3"><property name="visible">True</property><property name="label">3 mm</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_thick_3_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkButton" id="thick_4"><property name="visible">True</property><property name="label">4 mm</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_thick_4_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkButton" id="thick_6"><property name="visible">True</property><property name="label">6 mm</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_thick_6_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkButton" id="thick_8"><property name="visible">True</property><property name="label">8 mm</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_thick_8_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkButton" id="thick_10"><property name="visible">True</property><property name="label">10 mm</property><property name="width_request">74</property><property name="height_request">44</property><signal name="clicked" handler="on_thick_10_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkButton" id="thick_12"><property name="visible">True</property><property name="label">12 mm</property><property name="width_request">74</property><property name="height_request">44</property><signal name="clicked" handler="on_thick_12_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkEntry" id="entry_thickness"><property name="visible">True</property><property name="width_request">80</property><property name="height_request">44</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                  </object>
                </child>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property></packing>
            </child>

            <child>
              <object class="GtkFrame" id="frame_diameter">
                <property name="visible">True</property>
                <property name="label">Hole diameter</property>
                <child>
                  <object class="GtkVBox" id="dia_box">
                    <property name="visible">True</property>
                    <property name="spacing">4</property>

                    <child><object class="GtkHBox" id="dia_row1"><property name="visible">True</property><property name="spacing">4</property>
                      <child><object class="GtkButton" id="dia_10"><property name="visible">True</property><property name="label">10</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_10_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_15"><property name="visible">True</property><property name="label">15</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_15_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_20"><property name="visible">True</property><property name="label">20</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_20_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_25"><property name="visible">True</property><property name="label">25</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_25_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_30"><property name="visible">True</property><property name="label">30</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_30_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_35"><property name="visible">True</property><property name="label">35</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_35_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    </object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>

                    <child><object class="GtkHBox" id="dia_row2"><property name="visible">True</property><property name="spacing">4</property>
                      <child><object class="GtkButton" id="dia_40"><property name="visible">True</property><property name="label">40</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_40_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_45"><property name="visible">True</property><property name="label">45</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_45_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_50"><property name="visible">True</property><property name="label">50</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_50_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_55"><property name="visible">True</property><property name="label">55</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_55_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="dia_60"><property name="visible">True</property><property name="label">60</property><property name="width_request">70</property><property name="height_request">44</property><signal name="clicked" handler="on_dia_60_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkEntry" id="entry_custom_dia"><property name="visible">True</property><property name="width_request">80</property><property name="height_request">44</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      <child><object class="GtkButton" id="custom_set"><property name="visible">True</property><property name="label">Custom</property><property name="width_request">90</property><property name="height_request">44</property><signal name="clicked" handler="on_custom_set_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    </object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                  </object>
                </child>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property></packing>
            </child>

            <child>
              <object class="GtkFrame" id="frame_pattern">
                <property name="visible">True</property>
                <property name="label">Hole pattern</property>
                <child>
                  <object class="GtkVBox" id="pattern_box">
                    <property name="visible">True</property>
                    <property name="spacing">4</property>

                    <child>
                      <object class="GtkHBox" id="count_box">
                        <property name="visible">True</property>
                        <property name="spacing">4</property>
                        <child><object class="GtkLabel" id="lbl_count"><property name="visible">True</property><property name="label">Count</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkButton" id="count_1"><property name="visible">True</property><property name="label">1</property><property name="width_request">64</property><property name="height_request">44</property><signal name="clicked" handler="on_count_1_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkButton" id="count_2"><property name="visible">True</property><property name="label">2</property><property name="width_request">64</property><property name="height_request">44</property><signal name="clicked" handler="on_count_2_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkButton" id="count_5"><property name="visible">True</property><property name="label">5</property><property name="width_request">64</property><property name="height_request">44</property><signal name="clicked" handler="on_count_5_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkButton" id="count_10"><property name="visible">True</property><property name="label">10</property><property name="width_request">64</property><property name="height_request">44</property><signal name="clicked" handler="on_count_10_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkEntry" id="entry_count"><property name="visible">True</property><property name="width_request">78</property><property name="height_request">44</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      </object>
                      <packing><property name="expand">False</property><property name="fill">False</property></packing>
                    </child>

                    <child>
                      <object class="GtkHBox" id="spacing_box">
                        <property name="visible">True</property>
                        <property name="spacing">4</property>
                        <child><object class="GtkLabel" id="lbl_spacing"><property name="visible">True</property><property name="label">Spacing</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkEntry" id="entry_spacing"><property name="visible">True</property><property name="width_request">90</property><property name="height_request">44</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkLabel" id="lbl_direction"><property name="visible">True</property><property name="label">Direction</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkButton" id="direction_x_pos"><property name="visible">True</property><property name="label">+X</property><property name="width_request">62</property><property name="height_request">44</property><signal name="clicked" handler="on_direction_x_pos_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkButton" id="direction_x_neg"><property name="visible">True</property><property name="label">-X</property><property name="width_request">62</property><property name="height_request">44</property><signal name="clicked" handler="on_direction_x_neg_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkButton" id="direction_y_pos"><property name="visible">True</property><property name="label">+Y</property><property name="width_request">62</property><property name="height_request">44</property><signal name="clicked" handler="on_direction_y_pos_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                        <child><object class="GtkButton" id="direction_y_neg"><property name="visible">True</property><property name="label">-Y</property><property name="width_request">62</property><property name="height_request">44</property><signal name="clicked" handler="on_direction_y_neg_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                      </object>
                      <packing><property name="expand">False</property><property name="fill">False</property></packing>
                    </child>
                  </object>
                </child>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property></packing>
            </child>

            <child>
              <object class="GtkFrame" id="frame_tool">
                <property name="visible">True</property>
                <property name="label">Tool / feed</property>
                <child>
                  <object class="GtkHBox" id="tool_box">
                    <property name="visible">True</property>
                    <property name="spacing">4</property>
                    <child><object class="GtkLabel" id="lbl_tool_no"><property name="visible">True</property><property name="label">T</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkEntry" id="entry_tool_no"><property name="visible">True</property><property name="width_request">60</property><property name="height_request">36</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkLabel" id="lbl_tool_dia"><property name="visible">True</property><property name="label">Diameter</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkEntry" id="entry_tool_dia"><property name="visible">True</property><property name="width_request">70</property><property name="height_request">36</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkLabel" id="lbl_feed"><property name="visible">True</property><property name="label">Feed</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkEntry" id="entry_feed"><property name="visible">True</property><property name="width_request">80</property><property name="height_request">36</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkCheckButton" id="check_local_mode"><property name="visible">True</property><property name="label">Local mode - skip tool change</property><property name="height_request">36</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                    <child><object class="GtkButton" id="refresh"><property name="visible">True</property><property name="label">OK</property><property name="width_request">70</property><property name="height_request">36</property><signal name="clicked" handler="on_refresh_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
                  </object>
                </child>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property></packing>
            </child>

            <child>
              <object class="GtkLabel" id="label_status">
                <property name="visible">True</property>
                <property name="label">Selected...</property>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property></packing>
            </child>

            <child>
              <object class="GtkButton" id="run_button">
                <property name="visible">True</property>
                <property name="label">CUT RELIEF HOLE</property>
                <property name="width_request">520</property>
                <property name="height_request">54</property>
                <signal name="clicked" handler="on_run_clicked"/>
              </object>
              <packing><property name="expand">False</property><property name="fill">False</property></packing>
            </child>

          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
