%
(UNIVERSAL RELIEF HOLE MACRO FOR LINUXCNC)
(Usage: o<relief_hole> call [hole_diameter] [material_thickness] [tool_number] [tool_diameter] [cutting_feed])
o<relief_hole> sub

    #<hole_dia>   = #1
    #<mat_thick>  = #2
    #<tool_no>    = #3
    #<tool_dia>   = #4
    #<cut_feed>   = #5

    #<plunge_feed> = 50
    #<spindle_rpm> = 20000
    #<safe_z>      = 8
    #<start_z>     = 3
    #<near_z>      = 0.2

    #<r>       = [[#<hole_dia> / 2] - [#<tool_dia> / 2]]
    #<z_final> = [0 - #<mat_thick>]
    #<z_pre>   = [#<z_final> + 0.1]

    o100 if [#<r> LE 0]
        (MSG, ERROR: TOOL DIAMETER IS TOO LARGE FOR THIS HOLE)
        M2
    o100 endif

    G0 Z#<safe_z>
    T#<tool_no> M6
    G43 H#<tool_no>

    G21
    G17
    G90
    G94
    G54
    G64 P0.01 Q0.01

    S#<spindle_rpm> M3
    G4 P2

    G0 Z#<safe_z>
    G0 X[#<r> - 0.3] Y-0.1
    G0 Z#<start_z>

    G1 Z#<near_z> F#<plunge_feed>
    G1 Z#<z_pre>

    G1 X[#<r> - 0.292] Z[#<z_pre> - 0.038] F#<cut_feed>
    G1 X[#<r> - 0.271] Z[#<z_pre> - 0.071]
    G1 X[#<r> - 0.238] Z[#<z_pre> - 0.092]
    G1 X[#<r> - 0.2] Z#<z_final>
    G1 X[#<r> - 0.1]
    G1 X[#<r> - 0.062] Y-0.092
    G1 X[#<r> - 0.029] Y-0.071
    G1 X[#<r> - 0.008] Y-0.038
    G1 X#<r> Y0

    G3 X[-#<r>] I[-#<r>] J0
    G3 X#<r> I#<r> J0

    G1 X[#<r> - 0.008] Y0.038
    G1 X[#<r> - 0.029] Y0.071
    G1 X[#<r> - 0.062] Y0.092
    G1 X[#<r> - 0.1] Y0.1
    G1 X[#<r> - 0.2]
    G1 X[#<r> - 0.238] Z[#<z_pre> - 0.092]
    G1 X[#<r> - 0.271] Z[#<z_pre> - 0.071]
    G1 X[#<r> - 0.292] Z[#<z_pre> - 0.038]
    G1 X[#<r> - 0.3] Z#<z_pre>

    G0 Z#<safe_z>
    M5

o<relief_hole> endsub
M2
%
