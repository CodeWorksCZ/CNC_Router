	                        <property name="spacing">4</property>
	                        <child><object class="GtkLabel" id="lbl_count"><property name="visible">True</property><property name="label">Count</property></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
	                        <child><object class="GtkButton" id="count_1"><property name="visible">True</property><property name="label">1</property><property name="width_request">54</property><property name="height_request">44</property><signal name="clicked" handler="on_count_1_clicked"/></object><packing><property name="expand">False</property><property name="fill">False</property></packing></child>
